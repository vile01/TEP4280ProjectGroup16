FoamFile
{
    version     2.0;
    format      ascii;
    class       polyBoundaryMesh;
    location    "constant/polyMesh";
    object      boundary;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

8
(
    inlet
    {
        type            patch;
        nFaces          0;
        startFace       445;
    }
    outlet
    {
        type            patch;
        nFaces          5;
        startFace       445;
    }
    wall
    {
        type            wall;
        inGroups        1(wall);
        nFaces          50;
        startFace       450;
    }
    back
    {
        type            wedge;
        inGroups        1(wedge);
        nFaces          250;
        startFace       500;
    }
    front
    {
        type            wedge;
        inGroups        1(wedge);
        nFaces          250;
        startFace       750;
    }
    axis
    {
        type            empty;
        inGroups        1(empty);
        nFaces          0;
        startFace       1000;
    }
    procBoundary7to3
    {
        type            processor;
        inGroups        1(processor);
        nFaces          50;
        startFace       1000;
        matchTolerance  0.0001;
        transform       unknown;
        myProcNo        7;
        neighbProcNo    3;
    }
    procBoundary7to6
    {
        type            processor;
        inGroups        1(processor);
        nFaces          5;
        startFace       1050;
        matchTolerance  0.0001;
        transform       unknown;
        myProcNo        7;
        neighbProcNo    6;
    }
)

