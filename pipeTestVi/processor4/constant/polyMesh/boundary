FoamFile
{
    version     2.0;
    format      ascii;
    class       polyBoundaryMesh;
    location    "constant/polyMesh";
    object      boundary;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

6
(
    fixedWalls
    {
        type            wall;
        inGroups        1(wall);
        nFaces          20;
        startFace       760;
    }
    inlet
    {
        type            patch;
        nFaces          20;
        startFace       780;
    }
    outlet
    {
        type            patch;
        nFaces          0;
        startFace       800;
    }
    frontAndBack
    {
        type            empty;
        inGroups        1(empty);
        nFaces          800;
        startFace       800;
    }
    procBoundary4to0
    {
        type            processor;
        inGroups        1(processor);
        nFaces          20;
        startFace       1600;
        matchTolerance  0.0001;
        transform       unknown;
        myProcNo        4;
        neighbProcNo    0;
    }
    procBoundary4to5
    {
        type            processor;
        inGroups        1(processor);
        nFaces          20;
        startFace       1620;
        matchTolerance  0.0001;
        transform       unknown;
        myProcNo        4;
        neighbProcNo    5;
    }
)

